{
  "name": "ginko-test",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "api": "json-server --watch db.json --port 3000",
    "dev:all": "concurrently -n api,web -c blue,green \"npm run api\" \"npm run dev\"",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "axios": "^1.16.1",
    "element-plus": "^2.14.0",
    "pinia": "^3.0.4",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.1.0",
    "vue": "^3.5.34",
    "vue-router": "^5.0.7"
  },
  "devDependencies": {
    "@types/node": "^24.12.3",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/coverage-v8": "^4.1.7",
    "@vue/test-utils": "^2.4.10",
    "@vue/tsconfig": "^0.9.1",
    "concurrently": "^9.2.1",
    "jsdom": "^27.0.1",
    "json-server": "^1.0.0-beta.15",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "vitest": "^3.2.4",
    "vue-tsc": "^3.2.8"
  }
}
